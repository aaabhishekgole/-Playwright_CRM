{
  "name": "advance-playwright-framework-testing",
  "version": "0.1.0",
  "private": true,
  "description": "Advanced Playwright + TypeScript framework scaffolded from the blueprint and adapted to Gadget Seva Hub.",
  "scripts": {
    "test": "node scripts/run-with-reports.mjs",
    "test:raw": "playwright test",
    "test:headed": "node scripts/run-with-reports.mjs --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:chromium": "node scripts/run-with-reports.mjs --project=chromium",
    "test:firefox": "node scripts/run-with-reports.mjs --project=firefox",
    "test:webkit": "node scripts/run-with-reports.mjs --project=webkit",
    "test:mobile": "node scripts/run-with-reports.mjs --project=mobile-chrome",
    "test:smoke": "node scripts/run-with-reports.mjs --grep @Smoke",
    "test:regression": "node scripts/run-with-reports.mjs --grep @Regression",
    "test:p0": "node scripts/run-with-reports.mjs --grep @P0",
    "test:report": "playwright show-report Report/playwright",
    "report:dashboard": "vite build --config report-ui/vite.config.mjs",
    "report:dashboard:dev": "vite --config report-ui/vite.config.mjs",
    "report:allure": "allure open Report/allure",
    "report:generate": "node scripts/build-reports.mjs",
    "test:uat": "cross-env ENV_FILE=.env.uat node scripts/run-with-reports.mjs",
    "test:uat:headed": "cross-env ENV_FILE=.env.uat node scripts/run-with-reports.mjs --headed",
    "test:uat:smoke": "cross-env ENV_FILE=.env.uat node scripts/run-with-reports.mjs --grep @Smoke",
    "test:uat:regression": "cross-env ENV_FILE=.env.uat node scripts/run-with-reports.mjs --grep @Regression",
    "test:ci": "playwright test --reporter=list,json",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "rules:check": "node scripts/rule-engine.js",
    "rules:changed": "node scripts/rule-engine.js --changed",
    "rules:staged": "node scripts/rule-engine.js --staged"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.1",
    "@vitejs/plugin-react": "^4.3.4",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.6.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "eslint": "^9.17.0",
    "framer-motion": "^11.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "lucide-react": "^0.468.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
