# Local development
VITE_API_BASE_URL=http://localhost:8081/api

# Railway production
# Use the public Railway backend domain, or reference the backend service domain in Railway.
# VITE_API_BASE_URL=https://your-backend-domain.up.railway.app/api
# VITE_API_BASE_URL=https://${{backend.RAILWAY_PUBLIC_DOMAIN}}/api

# Vercel production
# Keep browser requests on the Vercel domain and let the Vercel proxy forward /api/*
# VITE_API_BASE_URL=/api
# BACKEND_API_ORIGIN=https://your-backend-domain.example.com
