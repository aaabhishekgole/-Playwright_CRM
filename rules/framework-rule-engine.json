{
  "pageDirectory": "src/pages",
  "moduleDirectory": "src/modules",
  "testDirectory": "src/tests",
  "rules": {
    "pageFileSuffix": "Page.ts",
    "moduleFileSuffix": "Module.ts",
    "testFileSuffix": ".spec.ts",
    "pageLocatorsMustUseArrowFunctions": true,
    "modulesMustNotUsePageLocatorDirectly": true,
    "testsMustUseDescribe": true,
    "testsMustUseTestStep": true,
    "testsMustNotImportPagesDirectly": true
  }
}
