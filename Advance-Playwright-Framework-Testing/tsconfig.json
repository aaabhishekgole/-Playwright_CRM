{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "typeRoots": ["./node_modules/@types", "../mobile/node_modules/@types"],
    "types": ["node"],
    "baseUrl": ".",
    "outDir": "dist",
    "paths": {
      "@api/*": ["src/api/*"],
      "@config/*": ["src/config/*"],
      "@fixtures/*": ["src/fixtures/*"],
      "@modules/*": ["src/modules/*"],
      "@pages/*": ["src/pages/*"],
      "@testdata/*": ["src/testdata/*"],
      "@utils/*": ["src/utils/*"]
    }
  },
  "include": ["playwright.config.ts", "src/**/*.ts", "scripts/**/*.js"],
  "exclude": ["dist", "node_modules"]
}
