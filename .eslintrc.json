{
  "root": true,
  "env": {
    "node": true,
    "es2022": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "ignorePatterns": [
    "dist",
    "playwright-report",
    "test-results",
    "tta-report"
  ],
  "rules": {
    "no-console": "off"
  }
}
