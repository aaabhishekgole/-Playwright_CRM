# Default local development uses the embedded H2 profile.
SPRING_PROFILES_ACTIVE=local
JWT_SECRET=01234567890123456789012345678901
STORAGE_ROOT=uploads
STORAGE_BASE_URL=http://localhost:8081

# Notification gateway
NOTIFICATION_PROVIDER=LOG
# NOTIFICATION_PROVIDER=HTTP
# NOTIFICATION_API_KEY=replace-with-provider-key
# NOTIFICATION_AUTH_HEADER=authkey
# NOTIFICATION_TIMEOUT=10s
# NOTIFICATION_SMS_ENABLED=true
# NOTIFICATION_SMS_URL=https://your-sms-gateway.example/send
# NOTIFICATION_SMS_SENDER_ID=GSHUB
# NOTIFICATION_WHATSAPP_ENABLED=true
# NOTIFICATION_WHATSAPP_URL=https://your-whatsapp-gateway.example/send
# NOTIFICATION_WHATSAPP_NUMBER=919999999999
# NOTIFICATION_WHATSAPP_TEMPLATE_NAME=pickup_runner_link

# Optional: uncomment these only when you want to run against a local Postgres instance.
# DB_URL=jdbc:postgresql://localhost:5432/gadget_seva_hub
# DB_USERNAME=gadget
# DB_PASSWORD=gadget
# REDIS_HOST=localhost
# REDIS_PORT=6379
