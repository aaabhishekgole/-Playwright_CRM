{
  "expo": {
    "name": "Gadget Seva Runner",
    "slug": "gadget-seva-runner",
    "version": "1.0.0",
    "scheme": "gshrunner",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "android": {
      "package": "com.gadgetseva.runner",
      "versionCode": 1,
      "usesCleartextTraffic": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "front-end-uat.up.railway.app",
              "pathPrefix": "/runner-access"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "ios": {
      "bundleIdentifier": "com.gadgetseva.runner",
      "buildNumber": "1"
    },
    "extra": {
      "privacyPolicyUrl": "https://front-end-uat.up.railway.app/privacy-policy",
      "eas": {
        "projectId": "gadget-seva-runner"
      }
    },
    "plugins": []
  }
}
