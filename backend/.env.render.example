# Render backend env template
# Use this for a PostgreSQL-backed deployment.

APP_PERSISTENCE_TYPE=jpa
DB_URL=jdbc:postgresql://your-render-postgres-host:5432/gadget_seva_hub
DB_USERNAME=your_render_db_user
DB_PASSWORD=your_render_db_password
REDIS_HOST=your-render-redis-host
REDIS_PORT=6379
JWT_SECRET=replace-with-a-32-plus-character-secret
JWT_EXPIRATION_MINUTES=120
STORAGE_ROOT=/var/data/uploads
STORAGE_BASE_URL=https://your-backend-service.onrender.com
STORAGE_SIGNING_SECRET=replace-with-a-storage-signing-secret
APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://your-vercel-project.vercel.app,https://your-custom-domain.example.com
APP_RUNNER_PORTAL_BASE_URL=https://your-vercel-project.vercel.app/runner-access
REPAIR_CENTER_STATE_CODE=29
NOTIFICATION_PROVIDER=LOG
NOTIFICATION_TIMEOUT=10s
NOTIFICATION_AUTH_HEADER=authkey
NOTIFICATION_API_KEY=
NOTIFICATION_SMS_ENABLED=false
NOTIFICATION_SMS_URL=
NOTIFICATION_SMS_SENDER_ID=GSHUB
NOTIFICATION_WHATSAPP_ENABLED=false
NOTIFICATION_WHATSAPP_URL=
NOTIFICATION_WHATSAPP_NUMBER=
NOTIFICATION_WHATSAPP_TEMPLATE_NAME=

# Render sets PORT automatically. The app now reads it through server.port=${PORT:8081}.

# Mongo alternative:
# SPRING_PROFILES_ACTIVE=mongo
# APP_PERSISTENCE_TYPE=mongo
# MONGODB_URI=mongodb+srv://username:password@cluster.example.net/gadget_seva_hub
